{
  "name": "aham-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create aham_calendar",
    "db:migrate:local": "wrangler d1 execute aham_calendar --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute aham_calendar --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
